generator client {

  provider = "prisma-client-js"

  output   = "../generated/prisma"

}



datasource db {

  provider = "postgresql"

}

model User {
  id        Int      @id @default(autoincrement())
  username  String
  email     String   @unique
  password  String?
   phone String?
  isGoogle  Boolean  @default(false)

  tickets   Ticket[]

  @@map("user")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String
  email    String @unique
  password String
  isGoogle  Boolean  @default(false)

  @@map("admin")
}

model Engineer {
  id         Int    @id @default(autoincrement())
  username   String
  email      String @unique
  password   String
  department String @default("General")
  phone      String @default("")
  employeeId String @default("")
  isGoogle  Boolean  @default(false)

  @@map("engineer")
}

model Technician {
  id         Int    @id @default(autoincrement())
  username   String
  email      String @unique
  password   String
  department String @default("General")
  area       String @default("General")
  phone      String @default("")
  employeeId String @default("")
  isGoogle  Boolean  @default(false)

  @@map("technician")
}

model Ticket {
  id       Int     @id @default(autoincrement())
  type     String
  subject  String
  body     String
  area     String  @default("")
  location String  @default("")
  imageUrl String  @default("")
  prevId   Int?
  prev     Ticket?  @relation("TicketChain", fields: [prevId], references: [id])
  next     Ticket[] @relation("TicketChain")
  status   String

  satisfied Boolean @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("ticket")
}

model Otp {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  otp       String
  expiresAt DateTime
  
  @@map("otp")
}

model PushSubscription {
  id             Int    @id @default(autoincrement())
  endpoint       String @unique
  p256dh         String
  auth           String
  subscriberType String
  subscriberId   Int

  @@map("push_subscription")
}